<script>
const SCENES = 7;
const DURATIONS = [3800, 5500, 6000, 5500, 5000, 4500, 4500];
let current = 0;
let playing = false;
let timer = null;

function buildTimeline(){
  const tl = document.getElementById('timeline');
  tl.innerHTML = '';
  for(let i=0;i<SCENES;i++){
    const d = document.createElement('div');
    d.className = 'tl-dot' + (i===0?' current':'');
    d.onclick = ()=>goTo(i);
    tl.appendChild(d);
  }
}

function updateTimeline(){
  const dots = document.querySelectorAll('.tl-dot');
  dots.forEach((d,i)=>{
    d.className = 'tl-dot' + (i<current?' done':(i===current?' current':''));
  });
  document.getElementById('sceneNum').textContent =
    String(current+1).padStart(2,'0') + ' / 0' + SCENES;
  document.getElementById('progress').style.width = ((current+1)/SCENES*100)+'%';
}

function resetScene(idx){
  const old = document.getElementById('sc'+(idx+1));
  const clone = old.cloneNode(true);
  old.parentNode.replaceChild(clone, old);
  return clone;
}

function goTo(idx){
  const prevEl = document.getElementById('sc'+(current+1));
  if(prevEl) prevEl.classList.remove('active');
  current = Math.max(0, Math.min(SCENES-1, idx));
  const sc = resetScene(current);
  sc.classList.add('active');
  updateTimeline();
}

function next(){
  if(current < SCENES-1){
    goTo(current+1);
  } else {
    stopPlay();
  }
}

function startPlay(){
  playing = true;
  document.getElementById('playIco').className = '';
  document.getElementById('playIco').innerHTML =
    '<div class="pause-bar"><span></span><span></span></div>';
  scheduleNext();

  // MUSICA: decommentare per avviare la musica insieme al video
  // const music = document.getElementById('bgMusic');
  // if(music){ music.currentTime = 0; music.play().catch(()=>{}); }
}

function scheduleNext(){
  if(!playing) return;
  clearTimeout(timer);
  timer = setTimeout(()=>{
    next();
    if(playing && current < SCENES-1) scheduleNext();
    else if(current >= SCENES-1) stopPlay();
  }, DURATIONS[current]);
}

function stopPlay(){
  playing = false;
  clearTimeout(timer);
  document.getElementById('playIco').className = 'play-ico';
  document.getElementById('playIco').innerHTML = '';

  // MUSICA: decommentare per fermare la musica
  // const music = document.getElementById('bgMusic');
  // if(music) music.pause();
}

function togglePlay(){
  if(playing){ stopPlay(); }
  else {
    if(current >= SCENES-1) goTo(0);
    startPlay();
  }
}

document.getElementById('skipBtn').onclick = ()=>{
  if(current < SCENES-1){
    clearTimeout(timer);
    next();
    if(playing) scheduleNext();
  }
};

buildTimeline();
updateTimeline();

// Auto-start
setTimeout(()=>{ startPlay(); }, 900);
</script>
