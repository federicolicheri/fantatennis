<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{
  height:100%;
  background:#0A0A0A;
  font-family:'DM Sans',sans-serif;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

#stage{
  width:390px;
  height:692px;
  position:relative;
  background:#111;
  overflow:hidden;
  border-radius:32px;
  box-shadow:0 40px 100px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06);
}

/* Noise texture */
#stage::after{
  content:'';
  position:absolute;
  inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events:none;
  z-index:100;
  border-radius:32px;
}

/* Progress bar */
#progress{
  position:absolute;
  bottom:0;left:0;
  height:2px;
  background:linear-gradient(90deg,#993C1D,#D85A30);
  transition:width 0.5s ease;
  z-index:200;
  border-radius:0 1px 1px 0;
}

/* Scene counter */
#sceneNum{
  position:absolute;
  top:18px;left:20px;
  font-family:'Bebas Neue',sans-serif;
  font-size:12px;
  color:rgba(255,255,255,0.2);
  letter-spacing:2px;
  z-index:200;
}

/* Skip button */
#skipBtn{
  position:absolute;
  top:14px;right:16px;
  background:rgba(255,255,255,0.06);
  border:0.5px solid rgba(255,255,255,0.12);
  border-radius:20px;
  color:rgba(255,255,255,0.4);
  font-size:11px;
  padding:5px 13px;
  cursor:pointer;
  z-index:200;
  font-family:'DM Sans',sans-serif;
  transition:all 0.2s;
  letter-spacing:0.3px;
}
#skipBtn:hover{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.7)}

/* Scene base */
.scene{
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  opacity:0;
  pointer-events:none;
  transition:opacity 0.6s ease;
  padding:24px;
}
.scene.active{opacity:1;pointer-events:auto}

/* =====================
   SCENE 1 — INTRO
   ===================== */
.s1-glow{
  position:absolute;
  width:400px;height:400px;
  background:radial-gradient(circle,rgba(216,90,48,0.18) 0%,transparent 70%);
  top:50%;left:50%;
  transform:translate(-50%,-60%);
  pointer-events:none;
}
.s1-lines{
  position:absolute;
  inset:0;
  background-image:repeating-linear-gradient(0deg,transparent,transparent 39px,rgba(255,255,255,0.02) 40px);
  pointer-events:none;
}
.s1-logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:72px;
  letter-spacing:6px;
  color:#D85A30;
  line-height:1;
  transform:translateY(24px);
  opacity:0;
  animation:fadeUp 0.8s 0.4s cubic-bezier(.22,1,.36,1) forwards;
  text-shadow:0 0 60px rgba(216,90,48,0.3);
}
.s1-logo span{color:#F0EDE8}
.s1-separator{
  width:40px;height:1px;
  background:linear-gradient(90deg,transparent,rgba(216,90,48,0.6),transparent);
  margin:14px 0;
  opacity:0;
  animation:fadeIn 0.6s 1s forwards;
}
.s1-sub{
  font-size:12px;
  letter-spacing:4px;
  text-transform:uppercase;
  color:rgba(240,237,232,0.35);
  opacity:0;
  animation:fadeIn 0.6s 1.2s forwards;
}
.s1-tag{
  margin-top:36px;
  font-size:12px;
  color:rgba(240,237,232,0.55);
  background:rgba(216,90,48,0.1);
  border:0.5px solid rgba(216,90,48,0.25);
  border-radius:20px;
  padding:7px 18px;
  opacity:0;
  animation:fadeUp 0.5s 1.6s forwards;
  letter-spacing:0.3px;
}
.s1-dots{
  display:flex;gap:7px;
  margin-top:56px;
  opacity:0;
  animation:fadeIn 0.5s 2s forwards;
}
.s1-dot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.12)}
.s1-dot.a{background:#D85A30;box-shadow:0 0 8px rgba(216,90,48,0.5)}

/* =====================
   SCENE 2 — ACCESSO
   ===================== */
.s2-icon{
  width:52px;height:52px;
  background:#1C1C1C;
  border:0.5px solid rgba(255,255,255,0.1);
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;
  margin-bottom:16px;
  opacity:0;
  animation:popIn 0.5s 0.2s forwards;
}
.s2-step{
  font-size:10px;text-transform:uppercase;letter-spacing:2px;
  color:#D85A30;margin-bottom:6px;
  opacity:0;animation:fadeIn 0.4s 0.5s forwards;
}
.s2-headline{
  font-size:22px;font-weight:500;color:#F0EDE8;
  margin-bottom:4px;
  opacity:0;animation:fadeUp 0.5s 0.6s forwards;
}
.s2-desc{
  font-size:12px;color:rgba(240,237,232,0.45);
  margin-bottom:24px;text-align:center;line-height:1.5;
  opacity:0;animation:fadeIn 0.4s 0.9s forwards;
}
.s2-card{
  width:300px;
  background:#1A1A1A;
  border:0.5px solid rgba(255,255,255,0.08);
  border-radius:12px;
  padding:20px;
  opacity:0;
  animation:popIn 0.5s 1s forwards;
}
.s2-field{
  background:#222;
  border:0.5px solid rgba(255,255,255,0.08);
  border-radius:7px;
  padding:8px 12px;
  margin-bottom:8px;
}
.s2-field label{
  display:block;font-size:9px;
  text-transform:uppercase;letter-spacing:0.5px;
  color:rgba(240,237,232,0.3);margin-bottom:3px;
}
.s2-field .val{font-size:12px;color:#F0EDE8;min-height:16px}
.s2-btn{
  width:100%;padding:10px;
  background:#D85A30;border:none;border-radius:7px;
  color:#fff;font-size:13px;font-weight:500;
  text-align:center;margin-top:6px;
  font-family:'DM Sans',sans-serif;
}
.s2-pwd-note{
  margin-top:14px;font-size:11px;
  color:rgba(240,237,232,0.35);text-align:center;
  background:rgba(255,255,255,0.03);border-radius:6px;
  padding:7px 10px;line-height:1.4;
  opacity:0;animation:fadeIn 0.5s 2.4s forwards;
}
.type-user{
  overflow:hidden;white-space:nowrap;
  animation:typeUser 0.7s steps(5) 1.6s forwards;
  width:0;
}
.type-pwd{
  overflow:hidden;white-space:nowrap;
  animation:typePwd 0.6s steps(8) 2s forwards;
  width:0;
}
.s2-mobile-tip{
  margin-top:14px;font-size:11px;
  color:rgba(240,237,232,0.3);text-align:center;
  opacity:0;animation:fadeIn 0.5s 2.8s forwards;
}

/* =====================
   SCENE 3 — DRAFT
   ===================== */
.s3-step{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#D85A30;margin-bottom:6px;opacity:0;animation:fadeIn 0.4s 0.2s forwards}
.s3-headline{font-size:22px;font-weight:500;color:#F0EDE8;margin-bottom:20px;opacity:0;animation:fadeUp 0.5s 0.4s forwards}
.s3-snake-wrap{opacity:0;animation:fadeUp 0.5s 0.7s forwards;margin-bottom:16px}
.s3-snake-row{display:flex;gap:4px;align-items:center;margin-bottom:4px;justify-content:center}
.s3-u{
  width:38px;height:38px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:9px;font-weight:600;color:#fff;
  flex-shrink:0;position:relative;
}
.s3-arrow{font-size:12px;color:rgba(255,255,255,0.2)}
.s3-pref{
  width:310px;
  background:#1A1A1A;
  border:0.5px solid rgba(255,255,255,0.08);
  border-radius:10px;
  padding:14px 16px;
  opacity:0;
  animation:fadeUp 0.5s 1.5s forwards;
}
.s3-pref-title{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:rgba(240,237,232,0.3);margin-bottom:10px}
.s3-pi{
  display:flex;align-items:center;gap:8px;
  padding:6px 8px;border-radius:6px;
  margin-bottom:3px;font-size:11px;color:#F0EDE8;
}
.s3-pi.top{background:rgba(216,90,48,0.1);border:0.5px solid rgba(216,90,48,0.2)}
.s3-pi-num{font-family:'Bebas Neue',sans-serif;font-size:15px;color:rgba(240,237,232,0.25);width:18px}
.s3-seed{font-size:8px;background:#D85A30;color:#fff;border-radius:2px;padding:1px 4px}
.s3-tip{
  margin-top:12px;font-size:11px;color:rgba(240,237,232,0.35);
  text-align:center;background:rgba(255,255,255,0.03);
  border-radius:6px;padding:7px 12px;line-height:1.5;
  opacity:0;animation:fadeIn 0.5s 2.4s forwards;
}
.s3-tip em{color:#D85A30;font-style:normal}

/* =====================
   SCENE 4 — PUNTEGGI
   ===================== */
.s4-step{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#D85A30;margin-bottom:6px;opacity:0;animation:fadeIn 0.4s 0.2s forwards}
.s4-headline{font-family:'Bebas Neue',sans-serif;font-size:48px;letter-spacing:3px;color:#F0EDE8;margin-bottom:4px;opacity:0;animation:fadeUp 0.5s 0.4s forwards}
.s4-sub{font-size:11px;color:rgba(240,237,232,0.35);margin-bottom:20px;opacity:0;animation:fadeIn 0.4s 0.7s forwards}
.s4-table{width:320px;opacity:0;animation:fadeUp 0.5s 0.9s forwards}
.s4-row{
  display:flex;align-items:center;
  padding:8px 12px;border-radius:7px;
  margin-bottom:3px;font-size:12px;color:#F0EDE8;
}
.s4-row.winner{background:rgba(216,90,48,0.1);border:0.5px solid rgba(216,90,48,0.2)}
.s4-row.normal{background:rgba(255,255,255,0.03)}
.s4-label{flex:1;color:rgba(240,237,232,0.75)}
.s4-pts{font-family:'Bebas Neue',sans-serif;font-size:22px;color:#D85A30}
.s4-pts.big{font-size:30px}
.s4-bonus{
  width:320px;margin-top:10px;
  background:rgba(243,156,18,0.07);
  border:0.5px solid rgba(243,156,18,0.2);
  border-radius:7px;padding:9px 14px;
  display:flex;align-items:flex-start;gap:10px;
  opacity:0;animation:fadeUp 0.5s 2s forwards;
}
.s4-bonus-text{font-size:11px;color:rgba(243,156,18,0.85);line-height:1.4}
.s4-note{margin-top:10px;font-size:10px;color:rgba(240,237,232,0.25);text-align:center;opacity:0;animation:fadeIn 0.4s 2.4s forwards}

/* =====================
   SCENE 5 — TABELLONE
   ===================== */
.s5-step{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#D85A30;margin-bottom:6px;opacity:0;animation:fadeIn 0.4s 0.2s forwards}
.s5-headline{font-size:22px;font-weight:500;color:#F0EDE8;margin-bottom:16px;opacity:0;animation:fadeUp 0.5s 0.4s forwards}
.s5-tabs{display:flex;gap:4px;margin-bottom:14px;opacity:0;animation:fadeIn 0.4s 0.6s forwards}
.s5-tab{
  font-size:10px;padding:4px 10px;
  border-radius:20px;border:0.5px solid rgba(255,255,255,0.1);
  color:rgba(240,237,232,0.35);font-family:'DM Sans',sans-serif;cursor:default;
}
.s5-tab.active{background:rgba(216,90,48,0.12);border-color:rgba(216,90,48,0.3);color:#D85A30}
.s5-bracket{width:320px;opacity:0;animation:fadeUp 0.5s 0.9s forwards}
.s5-match{
  border:1px solid rgba(216,90,48,0.2);
  border-radius:6px;overflow:hidden;
  margin-bottom:6px;background:rgba(216,90,48,0.04);
}
.s5-match.blue{border-color:rgba(41,128,185,0.2);background:rgba(41,128,185,0.04)}
.s5-match.green{border-color:rgba(39,174,96,0.2);background:rgba(39,174,96,0.04)}
.s5-p{
  display:flex;align-items:center;gap:6px;
  padding:6px 10px;font-size:11px;
  border-bottom:0.5px solid rgba(255,255,255,0.05);
}
.s5-p:last-child{border-bottom:none}
.s5-p.win{color:#F0EDE8;font-weight:500}
.s5-p.lose{color:rgba(240,237,232,0.3)}
.s5-p .sc{margin-left:auto;font-size:10px;color:#27AE60;font-weight:500}
.s5-p .sd{font-size:8px;background:#D85A30;color:#fff;border-radius:2px;padding:1px 3px}
.s5-legend{
  margin-top:12px;display:flex;gap:12px;justify-content:center;
  font-size:10px;color:rgba(240,237,232,0.3);
  opacity:0;animation:fadeIn 0.5s 1.8s forwards;
}
.s5-leg-item{display:flex;align-items:center;gap:4px}
.s5-tip{
  margin-top:12px;font-size:11px;color:rgba(240,237,232,0.35);
  text-align:center;opacity:0;animation:fadeIn 0.5s 2.2s forwards;
  line-height:1.5;
}
.s5-tip em{color:#D85A30;font-style:normal}

/* =====================
   SCENE 6 — CLASSIFICA
   ===================== */
.s6-step{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#D85A30;margin-bottom:6px;opacity:0;animation:fadeIn 0.4s 0.2s forwards}
.s6-headline{font-family:'Bebas Neue',sans-serif;font-size:48px;letter-spacing:3px;color:#F0EDE8;margin-bottom:18px;opacity:0;animation:fadeUp 0.5s 0.4s forwards}
.s6-list{width:310px;opacity:0;animation:fadeUp 0.5s 0.8s forwards}
.s6-row{
  display:flex;align-items:center;gap:10px;
  padding:8px 12px;
  border:0.5px solid rgba(255,255,255,0.06);
  border-radius:8px;margin-bottom:4px;
  background:#1C1C1C;
}
.s6-row.r1{border-left:2px solid #D85A30;background:#1E1A18}
.s6-pos{font-family:'Bebas Neue',sans-serif;font-size:18px;color:rgba(240,237,232,0.25);width:20px;text-align:center}
.s6-pos.p1{color:#D85A30}
.s6-av{
  width:28px;height:28px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:9px;font-weight:600;color:#fff;flex-shrink:0;
}
.s6-name{flex:1;font-size:12px;color:#F0EDE8}
.s6-pts{font-family:'Bebas Neue',sans-serif;font-size:20px;color:#F0EDE8}
.s6-cta{
  margin-top:16px;font-size:11px;
  color:rgba(240,237,232,0.4);
  border:0.5px solid rgba(255,255,255,0.1);
  border-radius:20px;padding:7px 18px;
  opacity:0;animation:fadeUp 0.5s 2.2s forwards;
}

/* =====================
   SCENE 7 — OUTRO
   ===================== */
.s7-glow{
  position:absolute;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(216,90,48,0.15) 0%,transparent 70%);
  top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;
}
.s7-clay{
  font-family:'Bebas Neue',sans-serif;
  font-size:13px;letter-spacing:6px;
  color:rgba(240,237,232,0.2);
  margin-bottom:16px;
  opacity:0;animation:fadeIn 0.6s 0.3s forwards;
}
.s7-logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:64px;letter-spacing:5px;
  color:#D85A30;line-height:1;
  text-shadow:0 0 80px rgba(216,90,48,0.25);
  opacity:0;animation:popIn 0.7s 0.6s cubic-bezier(.22,1,.36,1) forwards;
}
.s7-logo span{color:#F0EDE8}
.s7-sep{
  width:48px;height:1px;
  background:linear-gradient(90deg,transparent,rgba(216,90,48,0.5),transparent);
  margin:16px 0;
  opacity:0;animation:fadeIn 0.5s 1.2s forwards;
}
.s7-tagline{
  font-size:12px;letter-spacing:3px;text-transform:uppercase;
  color:rgba(240,237,232,0.35);
  opacity:0;animation:fadeIn 0.5s 1.4s forwards;
}
.s7-url{
  margin-top:36px;
  font-size:14px;color:#D85A30;
  background:rgba(216,90,48,0.08);
  border:0.5px solid rgba(216,90,48,0.25);
  border-radius:10px;padding:12px 28px;
  letter-spacing:0.5px;
  opacity:0;animation:fadeUp 0.6s 1.8s forwards;
}
.s7-good{
  margin-top:20px;font-size:13px;
  color:rgba(240,237,232,0.45);
  opacity:0;animation:fadeIn 0.5s 2.2s forwards;
}
.s7-admin{
  margin-top:48px;font-size:10px;letter-spacing:2px;
  text-transform:uppercase;color:rgba(240,237,232,0.18);
  opacity:0;animation:fadeIn 0.5s 2.6s forwards;
}

/* =====================
   CONTROLS
   ===================== */
#controls{
  position:absolute;
  bottom:22px;left:50%;
  transform:translateX(-50%);
  display:flex;align-items:center;gap:14px;
  z-index:300;
  opacity:0;
  animation:fadeIn 0.6s 1s forwards;
}
#playBtn{
  background:#D85A30;
  border:none;border-radius:50%;
  width:46px;height:46px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;flex-shrink:0;
  box-shadow:0 4px 20px rgba(216,90,48,0.3);
  transition:transform 0.15s,box-shadow 0.15s;
}
#playBtn:hover{transform:scale(1.05);box-shadow:0 6px 24px rgba(216,90,48,0.4)}
#playBtn:active{transform:scale(0.97)}
.play-ico{
  width:0;height:0;
  border-style:solid;
  border-width:7px 0 7px 14px;
  border-color:transparent transparent transparent #fff;
  margin-left:3px;
}
.pause-bar{display:flex;gap:4px;align-items:center}
.pause-bar span{width:3px;height:14px;background:#fff;border-radius:2px;display:block}
#timeline{display:flex;gap:5px;align-items:center}
.tl-dot{
  width:6px;height:6px;border-radius:50%;
  background:rgba(255,255,255,0.15);
  cursor:pointer;transition:all 0.2s;
}
.tl-dot:hover{background:rgba(255,255,255,0.35)}
.tl-dot.done{background:rgba(216,90,48,0.5)}
.tl-dot.current{background:#D85A30;transform:scale(1.35);box-shadow:0 0 6px rgba(216,90,48,0.5)}

/* =====================
   KEYFRAMES
   ===================== */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(18px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes popIn{
  from{opacity:0;transform:scale(0.86)}
  to{opacity:1;transform:scale(1)}
}
@keyframes typeUser{from{width:0}to{width:58px}}
@keyframes typePwd{from{width:0}to{width:76px}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
</style>
</head>
<body>
<div id="stage">
  <div id="progress"></div>
  <div id="sceneNum">01 / 07</div>
  <button id="skipBtn">Salta →</button>

  <!-- ====== SCENE 1 — INTRO ====== -->
  <div class="scene active" id="sc1">
    <div class="s1-glow"></div>
    <div class="s1-lines"></div>
    <div class="s1-logo">Fanta<span>Tennis</span></div>
    <div class="s1-separator"></div>
    <div class="s1-sub">Clay Kings · Stagione 2025/2026</div>
    <div class="s1-tag">🎾 Guida rapida per i partecipanti</div>
    <div class="s1-dots">
      <div class="s1-dot a"></div>
      <div class="s1-dot"></div><div class="s1-dot"></div>
      <div class="s1-dot"></div><div class="s1-dot"></div>
      <div class="s1-dot"></div>
    </div>
  </div>

  <!-- ====== SCENE 2 — ACCESSO ====== -->
  <div class="scene" id="sc2">
    <div class="s2-icon">🎾</div>
    <div class="s2-step">01 — Accesso</div>
    <div class="s2-headline">Come entrare nell'app</div>
    <div class="s2-desc">Apri <strong style="color:#D85A30">fantatennis-rust.vercel.app</strong><br>e inserisci le credenziali ricevute da Fritz</div>
    <div class="s2-card">
      <div class="s2-field">
        <label>Username</label>
        <div class="val">
          <span class="type-user">sdl88</span>
        </div>
      </div>
      <div class="s2-field">
